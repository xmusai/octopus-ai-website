# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── Admin Dashboard ────────────────────────────────────────────────
# Change this to a long random string (e.g. openssl rand -hex 32)
ADMIN_TOKEN=change-me-to-a-long-random-secret

# ── Email (SMTP) ───────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# Gmail App Passwords: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Who receives new lead notifications (defaults to SMTP_USER if not set)
NOTIFY_EMAIL=andres@octopusai.com

# ── CORS (optional, restrict to your domain in production) ─────────
# ALLOWED_ORIGIN=https://octopusai.com
